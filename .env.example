# ============================================================
# Folder Watcher → ADLS Gen2 설정
# ============================================================

# 감시할 로컬 폴더
WATCH_FOLDER=S:\Watcher

# 허용 확장자 (콤마로 구분, 점 포함/미포함 모두 가능)
ALLOWED_EXTENSIONS=.zip

# ADLS Gen2 DFS endpoint URI (반드시 dfs.core.windows.net)
ADLS_DFS_URI=https://mskrblobv2.dfs.core.windows.net/

# 컨테이너(filesystem) 이름
ADLS_CONTAINER=watcher

# (선택) 컨테이너 내부 prefix. 비워두면 루트에 yyyy/MM/dd/파일명 으로 저장
ADLS_TARGET_PREFIX=

# 업로드 완료 후 원본 파일을 이동시킬 아카이브 루트 폴더
# 실제 저장 경로 = {ARCHIVE_FOLDER}\{YYYYMMDD}\파일명
ARCHIVE_FOLDER=S:\Watcher\ARCHIVED

# 파일 쓰기 완료 감지(크기 안정 체크) 설정
STABLE_CHECK_INTERVAL=1.0
STABLE_CHECK_RETRIES=5

# 디바운스: 마지막 이벤트(생성/매 modify) 이후 N초 동안 이벤트가 없어야 처리
# 큰 파일 쓰기 중 수십~수백번 발생하는 modified 이벤트를 합치는 용도
DEBOUNCE_SECONDS=2.0

# 배타적 열기 체크 (Windows 권장)
# writer 가 파일을 잡고 있으면 PermissionError 가 발생해 쓰기 중 파일을 잘 감지
USE_EXCLUSIVE_LOCK_CHECK=true
LOCK_CHECK_RETRIES=10
LOCK_CHECK_INTERVAL=1.0
